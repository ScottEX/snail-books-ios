{
  "name": "snail-books-ios",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:ios": "expo prebuild --platform ios && xcodebuild -workspace ios/*.xcworkspace -scheme app -configuration Release -quiet",
    "prebuild": "expo prebuild --platform ios",
    "postinstall": "patch-package && bash scripts/tunnel/check-prebuild.sh"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/datetimepicker": "8.2.0",
    "@react-native-community/slider": "4.5.5",
    "@react-navigation/native": "^7.3.11",
    "@react-navigation/native-stack": "^7.18.3",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-blur": "~14.0.3",
    "expo-file-system": "~18.0.12",
    "expo-image": "~2.0.7",
    "expo-image-manipulator": "~13.0.6",
    "expo-image-picker": "~16.0.0",
    "expo-linear-gradient": "~14.0.2",
    "expo-linking": "~7.0.0",
    "expo-local-authentication": "~15.0.2",
    "expo-localization": "~16.0.1",
    "expo-status-bar": "~2.0.1",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-gifted-charts": "^1.4.77",
    "react-native-keyboard-controller": "^1.21.14",
    "react-native-keychain": "^10.0.0",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "~15.8.0",
    "react-native-webview": "13.12.5"
  },
  "devDependencies": {
    "@types/react": "~18.3.0",
    "patch-package": "^8.0.0",
    "typescript": "~5.3.3"
  }
}
